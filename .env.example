# ─────────────────────────────────────────────────────────────────────────
# Core
# ─────────────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/shopify_profit_ops"
APP_URL="http://localhost:3000"

# ─────────────────────────────────────────────────────────────────────────
# Shopify
# ─────────────────────────────────────────────────────────────────────────
SHOPIFY_CREDENTIALS_ENCRYPTION_KEY="replace-with-a-long-random-secret"
SHOPIFY_ADMIN_API_VERSION="2026-01"
SHOPIFY_WEBHOOK_SECRET="replace-with-your-shopify-webhook-secret"
SHOPIFY_CLIENTID=""
SHOPIFY_CLIENT_SECRET=""

# Background sync cron.
# Opt-in: crons default OFF in development, ON in production. Set to "1" to run
# the hourly Shopify full-sync locally.
ENABLE_SHOPIFY_SYNC_CRON=""
# SHOPIFY_SYNC_CRON_DISABLED="1"   # hard kill switch (overrides ENABLE_* above)
# SHOPIFY_SYNC_CRON_MS="3600000"
# SHOPIFY_SYNC_CRON_URL=""

# ─────────────────────────────────────────────────────────────────────────
# Growth Agent
# ─────────────────────────────────────────────────────────────────────────
GROWTH_AGENT_DEFAULT_APPROVER="merchant"
GROWTH_AGENT_PRODUCT_CRAWLER_DEFAULT_URLS=""
GROWTH_AGENT_PRODUCT_CRAWLER_USER_AGENT="ShopifyProfitOpsBot/0.1"

# ─────────────────────────────────────────────────────────────────────────
# Ads / analytics integrations
# ─────────────────────────────────────────────────────────────────────────
META_ADS_CLIENT_ID=""
META_ADS_CLIENT_SECRET=""
# Per-brand bucketing for the weekly Meta Ads report (/weekly-summary export
# to PDF). JSON array of {brand, match} where `match` is a regex applied to
# the campaign name (case-insensitive). Order matters — the first matching
# rule wins. Leave unset to put every campaign in a single "All campaigns"
# bucket.
# Example: META_ADS_BRAND_RULES='[{"brand":"Bushido","match":"^Bushido"},{"brand":"Linda","match":"^Linda"}]'
META_ADS_BRAND_RULES=""

# ─────────────────────────────────────────────────────────────────────────
# Weekly + Monthly auto-reports
# ─────────────────────────────────────────────────────────────────────────
# Resend transactional email for the auto-generated weekly/monthly PDFs.
# Get a key at https://resend.com/api-keys
RESEND_API_KEY=""
# Verified-domain sender. Format: 'Display Name <reports@yourdomain.com>'.
# Must be a domain you've verified in your Resend dashboard.
REPORT_FROM_EMAIL=""
# Cron knobs.
# Opt-in: crons default OFF in development, ON in production. Set to "1" to run
# the weekly/monthly auto-report scheduler locally.
ENABLE_WEEKLY_REPORT_CRON=""
# WEEKLY_REPORT_CRON_DISABLED="1"           # hard kill switch (overrides ENABLE_* above)
# WEEKLY_REPORT_CRON_MS="300000"            # default: 5 min polling
# WEEKLY_REPORT_CRON_URL=""                 # default: http://127.0.0.1:$PORT/api/weekly-summary/cron/run
TIKTOK_ADS_CLIENT_ID=""
TIKTOK_ADS_CLIENT_SECRET=""
GA4_CLIENT_ID=""
GA4_CLIENT_SECRET=""

# ═════════════════════════════════════════════════════════════════════════
# Creative Studio
# ═════════════════════════════════════════════════════════════════════════

# ─── AI providers ────────────────────────────────────────────────────────
# Replicate (Flux family for images, Veo for video — M3).
# Get a token at https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=""
# Override Replicate model IDs (defaults: flux-1.1-pro and flux-schnell).
CREATIVE_IMAGE_MODEL_DEFAULT=""
CREATIVE_IMAGE_MODEL_FAST=""

# Higgsfield (Soul for images, DoP for video).
# Verify endpoint paths against https://platform.higgsfield.ai docs.
HIGGSFIELD_API_KEY=""
HIGGSFIELD_API_BASE_URL=""          # default: https://api.higgsfield.ai/v1
HIGGSFIELD_IMAGE_MODEL=""           # default: soul
HIGGSFIELD_VIDEO_MODEL=""           # default: dop-v1

# Nano Banana — Google Gemini 2.5 Flash Image (image-only).
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=""
GEMINI_API_BASE_URL=""              # default: https://generativelanguage.googleapis.com/v1beta
NANOBANANA_MODEL=""                 # default: gemini-2.5-flash-image-preview

# OpenAI — gpt-image-1 (image-only).
# Get a key at https://platform.openai.com/api-keys (account must have gpt-image-1 access).
OPENAI_API_KEY=""
OPENAI_API_BASE_URL="https://api.openai.com/v1"
OPENAI_IMAGE_MODEL="gpt-image-1"
OPENAI_ORG_ID=""                    # optional
# gpt-image-1 fidelity: "low" | "medium" | "high" | "auto". Default: "high"
# (sharp detail, legible labels, real skin). "high" costs ≈ 4× more per image
# than "medium" — set to "medium" or "low" only for cheap previews.
OPENAI_IMAGE_QUALITY=""

# Batch quality: "fast" (cheap previews) or "pro" (sharp output). Default: pro.
CREATIVE_BATCH_QUALITY=""
# Concurrent provider calls inside one batch job. Default: 3.
CREATIVE_PROVIDER_CONCURRENCY=""

# ─── Storage ─────────────────────────────────────────────────────────────
# Backend: "local" (default, writes under ./.creative-storage) or "r2"/"s3".
CREATIVE_STORAGE_BACKEND="local"
CREATIVE_STORAGE_LOCAL_DIR=""

# Only used when CREATIVE_STORAGE_BACKEND is r2/s3.
CREATIVE_BUCKET=""
CREATIVE_S3_ENDPOINT=""              # R2: https://<account_id>.r2.cloudflarestorage.com
CREATIVE_S3_REGION="auto"
CREATIVE_S3_ACCESS_KEY_ID=""
CREATIVE_S3_SECRET_ACCESS_KEY=""

# ─── M2 job queue ────────────────────────────────────────────────────────
# In-process cron that pings the worker route.
# Opt-in: crons default OFF in development, ON in production. Set to "1" to run
# the creative job worker locally.
ENABLE_CREATIVE_JOB_CRON=""
CREATIVE_JOB_CRON_DISABLED=""        # hard kill switch (overrides ENABLE_* above)
CREATIVE_JOB_CRON_MS=""              # default: 5000 (5s)
CREATIVE_JOB_CRON_URL=""             # default: http://127.0.0.1:$PORT/api/creative/jobs/worker
# Shared secret sent in x-creative-worker-secret. Set in production.
CREATIVE_WORKER_SECRET=""

# ─── M3 video gating ─────────────────────────────────────────────────────
# Set to "1" to allow UGC_VIDEO projects to generate actual video clips
# (otherwise UGC_VIDEO falls back to a still frame).
CREATIVE_VIDEO_ENABLED=""
# Hard cap on clips per batch (safety against surprise spend). Default: 10.
CREATIVE_MAX_VIDEO_BATCH=""
# Replicate video model override. Default: google/veo-3-fast (~$0.40/clip).
CREATIVE_VIDEO_MODEL_DEFAULT=""
