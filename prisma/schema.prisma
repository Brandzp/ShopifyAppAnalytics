// ─── Creative Sprint (SA-SPRINT-01) ──────────────────────────────────
// Automated "N ads × small budget × 6h test → keep winners" loop.
// Generates targetCount distinct creatives via an AI provider (Higgsfield),
// publishes each as a standalone Meta adset with a small daily budget, then
// runs a 3-stage waterfall evaluator (defaults: 6h CTR → 24h CPC → 72h CPA)
// that pauses the bottom X% at each stage. Survivors become evergreen ads.
//
// Two models:
//   CreativeSprint — the sprint container (config + lifecycle + cascade plan)
//   SprintAd       — one row per ad slot, owning brief, asset, Meta IDs,
//                    cascade decisions, and the latest KPI snapshot.
//
// Cascade is stored as JSON on the sprint (small, infrequent reads) and the
// per-stage decisions are appended to a JSON log on each SprintAd (audit
// trail without an extra table). If we later want cross-sprint analytics
// over individual stage decisions, split into a SprintCascadeDecision table.
// String columns instead of enums to match the rest of the schema.

model CreativeSprint {
  id                     String     @id @default(cuid())
  storeId                String
  // Operator-visible label, e.g. "July perfume push 100x".
  name                   String
  // Shopify product the ads promote. Drives brief generation context
  // (image, title, USP). Nullable for brand-level (no single product) sprints.
  productId              String?
  // ─── Targets ────────────────────────────────────────────────────────
  // How many ads to generate + publish. Default 100; pilot smoke runs use 10.
  targetCount            Int        @default(100)
  // Daily budget per ad in the sprint currency. 100 × ₪10 = ₪1000/day ceiling
  // before any kills. Meta paces this across 24h, so a 6h evaluation window
  // will only have consumed roughly a quarter of this per ad.
  dailyBudgetPerAd       Decimal    @db.Decimal(12, 2)
  currency               String     @default("ILS")
  // ─── Workflow mode ──────────────────────────────────────────────────
  // "full_auto" → no gates; briefs auto-generate, assets auto-publish.
  // "review_briefs" → human approves briefs before Higgsfield runs.
  // "review_assets" → human approves assets before Meta publish.
  // "review_both" → both gates. Default for the first sprint on any store.
  approvalMode           String     @default("review_both")
  // ─── Cascade plan (waterfall kill schedule) ─────────────────────────
  // JSON array of stages:
  //   { stage: 1, hoursAfterLaunch: 6,  metric: "ctr", killBottomPct: 70, minImpressions: 500 }
  //   { stage: 2, hoursAfterLaunch: 24, metric: "cpc", killBottomPct: 50, minImpressions: 1500 }
  //   { stage: 3, hoursAfterLaunch: 72, metric: "cpa", killBottomPct: 50, minImpressions: 4000 }
  // metric ∈ "ctr" | "cpc" | "cpa" | "roas". Ads below minImpressions are
  // exempted from kill (insufficient signal). Editable per sprint.
  cascadeJson            Json
  // Current stage index. 0 = pre-publish; 1, 2, 3 = post-stage-N decisions made.
  currentStage           Int        @default(0)
  // ─── Lifecycle ──────────────────────────────────────────────────────
  // "draft" | "generating_briefs" | "awaiting_brief_approval"
  //   | "generating_assets" | "awaiting_asset_approval"
  //   | "publishing" | "running" | "measuring" | "complete"
  //   | "cancelled" | "failed"
  status                 String     @default("draft")
  // ─── Meta linkage ───────────────────────────────────────────────────
  // The single Meta Campaign created for this sprint (holds all N adsets).
  metaCampaignId         String?
  // Targeting blob captured at launch (lookalike id, geo, age, interests)
  // so we can re-render the audience config later in the report UI.
  targetingJson          Json?
  // ─── Cost tracking ──────────────────────────────────────────────────
  estimatedHiggsfieldUsd Decimal?   @db.Decimal(10, 4)
  actualHiggsfieldUsd    Decimal?   @db.Decimal(10, 4)
  estimatedAdSpend       Decimal?   @db.Decimal(12, 2)
  actualAdSpend          Decimal?   @db.Decimal(12, 2)
  // ─── Notes + diagnostics ────────────────────────────────────────────
  notes                  String?
  errorMessage           String?
  // ─── Lifecycle timestamps (drive the report timeline) ───────────────
  briefsGeneratedAt      DateTime?
  briefsApprovedAt       DateTime?
  assetsGeneratedAt      DateTime?
  assetsApprovedAt       DateTime?
  publishedAt            DateTime?
  completedAt            DateTime?
  cancelledAt            DateTime?
  createdAt              DateTime   @default(now())
  updatedAt              DateTime   @updatedAt
  store                  Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  ads                    SprintAd[]

  @@index([storeId, status])
  @@index([storeId, createdAt(sort: Desc)])
  @@index([status])
}

model SprintAd {
  id                 String         @id @default(cuid())
  sprintId           String
  // Denormalized for fast multi-tenant queries (matches CreativeSource pattern).
  storeId            String
  // 1-based slot inside the sprint (1..targetCount). Drives matrix layout
  // in the UI and gives the operator a stable handle ("ad #47 was the winner").
  slotIndex          Int
  // ─── Brief (concept the LLM authored) ───────────────────────────────
  // Shape: { angle, headline, body, cta, visualPrompt, voicePrompt?, durationSec? }.
  // Editable during the review_briefs gate.
  briefJson          Json
  briefApprovedAt    DateTime?
  briefRejectedAt    DateTime?
  // ─── Higgsfield generation ──────────────────────────────────────────
  higgsfieldJobId    String?
  // Raw provider URL (signed, short-lived). Kept for traceability.
  higgsfieldAssetUrl String?
  // Our mirrored R2 key. Path convention:
  //   creative/<storeId>/sprints/<sprintId>/<slotIndex>.<ext>
  assetStorageKey    String?
  assetMimeType      String?
  assetWidth         Int?
  assetHeight        Int?
  assetDurationMs    Int?
  assetApprovedAt    DateTime?
  assetRejectedAt    DateTime?
  higgsfieldCostUsd  Decimal?       @db.Decimal(10, 4)
  // ─── Meta linkage ───────────────────────────────────────────────────
  metaAdsetId        String?
  metaCreativeId     String?
  metaAdId           String?
  // ─── Cascade outcomes (append-only audit log) ───────────────────────
  // Array of:
  //   { stage, evaluatedAt, metric, metricValue, impressions, clicks, spend,
  //     purchases, purchaseValue, decision: "kept" | "killed" | "exempt",
  //     reason }
  decisionsJson      Json           @default("[]")
  // "alive" → no kill decisions yet. "killed" → paused at some stage.
  // "winner" → survived all configured cascade stages.
  finalStatus        String         @default("alive")
  killedReason       String?
  killedAt           DateTime?
  // ─── Last KPI snapshot (refreshed by the cascade evaluator) ─────────
  // Cached so the matrix board renders without round-tripping to Meta.
  lastImpressions    Int            @default(0)
  lastClicks         Int            @default(0)
  lastSpend          Decimal        @default(0) @db.Decimal(12, 2)
  lastPurchases      Int            @default(0)
  lastPurchaseValue  Decimal        @default(0) @db.Decimal(12, 2)
  // Stored as fractions (0.0234 = 2.34%) for clean math; UI multiplies by 100.
  lastCtr            Decimal?       @db.Decimal(8, 6)
  lastCpc            Decimal?       @db.Decimal(12, 2)
  lastCpa            Decimal?       @db.Decimal(12, 2)
  lastRoas           Decimal?       @db.Decimal(8, 4)
  lastSyncedAt       DateTime?
  // ─── Lifecycle status ───────────────────────────────────────────────
  // "draft" | "brief_ready" | "generating" | "asset_ready" | "publishing"
  //   | "live" | "killed" | "winner" | "failed"
  status             String         @default("draft")
  errorMessage       String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  sprint             CreativeSprint @relation(fields: [sprintId], references: [id], onDelete: Cascade)
  store              Store          @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([sprintId, slotIndex])
  @@index([sprintId, status])
  @@index([sprintId, finalStatus])
  @@index([storeId, createdAt(sort: Desc)])
  @@index([metaAdsetId])
}

// Uploaded Gantt file. Each upload is immutable — operator re-uploads to
// replace. The parsed rows live in GanttRow. BI insights are cached as
// JSON on this row so the UI can re-render without a fresh agent call.
model GanttSheet {
  id            String      @id @default(cuid())
  storeId       String
  // Operator-visible label, defaults to the uploaded filename.
  title         String
  // Original filename + content type, for download / debugging.
  originalName  String
  contentType   String
  bytesLength   Int
  // R2/local key — the raw .xlsx is preserved so we can re-parse with
  // future schema improvements without asking the operator to re-upload.
  storageKey    String?
  // Span of the parsed rows (min start, max end) — cached for the UI list.
  rangeStart    DateTime?
  rangeEnd      DateTime?
  // Count of rows that parsed cleanly.
  rowCount      Int         @default(0)
  // Distinct roles + categories detected. Stored as JSON string arrays
  // so the UI can render filter chips without re-aggregating.
  rolesJson     Json        @default("[]")
  categoriesJson Json       @default("[]")
  // Every tab in the uploaded workbook + which one we actually parsed.
  // Lets the UI offer a "wrong tab? switch to..." picker without needing
  // to re-open the raw file server-side.
  sheetNamesJson Json       @default("[]")
  parsedSheetName String?
  // Cached BI agent output. Shape:
  //   { generatedAt, summary, insights: [{title, severity, body}], actions: [...] }
  insightsJson  Json?
  insightsGeneratedAt DateTime?
  // Cached MarketingBrief output (see gantt-brief-generator-service).
  briefJson     Json?
  briefGeneratedAt DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  store         Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  rows          GanttRow[]

  @@index([storeId, createdAt(sort: Desc)])
}

// One task row parsed from a Gantt upload. Minimum required fields are
// task name + role + category + start + end. Action mapping is optional —
// `actionType` lets the UI render an "execute" button (create discount,
// open Creative wizard, etc.). When null, the row is informational only.
model GanttRow {
  id           String     @id @default(cuid())
  sheetId      String
  // Denormalized for fast multi-tenant queries.
  storeId      String
  // 1-based index inside the source sheet — preserves the operator's
  // intentional ordering even after filtering.
  rowIndex     Int
  task         String
  role         String?
  category     String?
  startDate    DateTime?
  endDate      DateTime?
  // Free-form status text from the sheet (todo / in progress / done / etc.).
  status       String?
  // Optional action wiring. Values we currently understand:
  //   "discount_code" | "creative_image" | "creative_banner" |
  //   "creative_video" | "email_campaign" | "social_post" | "blog_post"
  // The UI maps each to an existing service. Null = no action button.
  actionType   String?
  // Action-specific payload (discount %, creative brief, etc.) — kept as
  // a JSON blob so different action types can use different schemas.
  actionPayloadJson Json?
  // Execution outcome — recorded when the operator clicks the action
  // button. Shape: { executedAt, providerRef, providerUrl, error }.
  executionJson Json?
  // Raw parsed cells from the row — kept for round-trip + debug. JSON
  // object keyed by lowercased header.
  rawJson      Json?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  sheet        GanttSheet @relation(fields: [sheetId], references: [id], onDelete: Cascade)
  store        Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([sheetId, rowIndex])
  @@index([sheetId, role])
  @@index([sheetId, category])
  @@index([sheetId, startDate])
  @@index([storeId, startDate])
}
