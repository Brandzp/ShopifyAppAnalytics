generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Store {
  id                         String                        @id @default(cuid())
  name                       String
  domain                     String                        @unique
  shopifyShopId              String?                       @unique
  currency                   String
  timezone                   String
  planName                   String?
  connected                  Boolean                       @default(false)
  dateRangePreset            String                        @default("30d")
  estimatedCostMode          String                        @default("margin_profile")
  defaultCostRatio           Decimal                       @default(0.35) @db.Decimal(5, 4)
  connection                 ShopifyConnection?
  bixgrowConnection          BixGrowConnection?
  instagramConnection        InstagramConnection?
  metaAdsConnection          MetaAdsConnection?
  products                   Product[]
  variants                   ProductVariant[]
  customers                  Customer[]
  orders                     Order[]
  lineItems                  OrderLineItem[]
  discountUsages             DiscountUsage[]
  refunds                    Refund[]
  dailyMetrics               DailyMetric[]
  summaries                  Summary[]
  alerts                     Alert[]
  syncRuns                   SyncRun[]
  creatorProfiles            CreatorProfile[]
  creatorPosts               CreatorPost[]
  creatorAttributions        CreatorAttribution[]
  affiliatePrograms          AffiliateProgram[]
  affiliateMembers           AffiliateMember[]
  affiliateCoupons           AffiliateCoupon[]
  affiliateCouponAssignments AffiliateCouponAssignment[]
  affiliateAttributions      AffiliateAttribution[]
  agentSettings              AgentSettings?
  agentFindings              AgentFinding[]
  agentActions               AgentAction[]
  platformConnections        PlatformConnection[]
  metricSnapshots            MetricSnapshot[]
  metaAdsCampaignInsights    MetaAdsCampaignInsight[]
  attributionSessions        AttributionSession[]
  webhookEvents              WebhookEvent[]
  shopifyCollections         ShopifyCollection[]
  productCollections         ProductCollectionMembership[]
  offlineSalesImports        OfflineSalesImport[]
  creativeProjects           CreativeProject[]
  creativeSources            CreativeSource[]
  creativeJobs               CreativeGenerationJob[]
  weeklyReports              WeeklyReport[]
  weeklyReportRecipients     WeeklyReportRecipient[]
  createdAt                  DateTime                      @default(now())
  updatedAt                  DateTime                      @updatedAt

  @@index([connected])
}

model ShopifyConnection {
  id                   String    @id @default(cuid())
  storeId              String    @unique
  shopDomain           String
  adminAccessTokenEnc  String
  tokenLastFour        String
  apiVersion           String    @default("2025-01")
  lastSyncAt           DateTime?
  lastProductsSyncAt   DateTime?
  lastCustomersSyncAt  DateTime?
  lastOrdersSyncAt     DateTime?
  lastSuccessfulSyncAt DateTime?
  syncStatus           String    @default("idle")
  lastSyncError        String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  store                Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([shopDomain])
  @@index([syncStatus])
}

model BixGrowConnection {
  id            String    @id @default(cuid())
  storeId       String    @unique
  portalDomain  String
  apiKeyEnc     String?
  tokenLastFour String?
  syncStatus    String    @default("idle")
  exportMode    String    @default("manual_export")
  lastSyncAt    DateTime?
  lastSyncError String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  store         Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([portalDomain])
}

model InstagramConnection {
  id              String        @id @default(cuid())
  storeId         String        @unique
  instagramUserId String
  username        String?
  accessTokenEnc  String
  tokenLastFour   String
  syncStatus      String        @default("idle")
  lastSyncAt      DateTime?
  lastSyncError   String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  store           Store         @relation(fields: [storeId], references: [id], onDelete: Cascade)
  posts           CreatorPost[]

  @@index([instagramUserId])
}

model MetaAdsConnection {
  id               String                   @id @default(cuid())
  storeId          String                   @unique
  adAccountId      String
  adAccountName    String?
  accountStatus    Int?
  currency         String?
  timezoneName     String?
  appId            String?
  appSecretEnc     String?
  accessTokenEnc   String
  tokenLastFour    String
  tokenType        String?
  tokenIssuedAt    DateTime?
  tokenExpiresAt   DateTime?
  tokenScopes      Json?
  syncStatus       String                   @default("idle")
  lastSyncAt       DateTime?
  lastSyncError    String?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  store            Store                    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  campaignInsights MetaAdsCampaignInsight[]

  @@index([adAccountId])
  @@index([syncStatus])
}

model MetaAdsCampaignInsight {
  id                     String             @id @default(cuid())
  storeId                String
  metaConnectionId       String?
  adAccountId            String
  entityId               String             @default("")
  campaignId             String
  campaignName           String
  adsetId                String?
  adsetName              String?
  adId                   String?
  adName                 String?
  creativeId             String?
  creativeName           String?
  creativeTitle          String?
  creativeBody           String?
  creativeThumbnailUrl   String?
  creativePreviewUrl     String?
  creativePermalinkUrl   String?
  creativeObjectUrl      String?
  objectStoryId          String?
  effectiveObjectStoryId String?
  level                  String             @default("campaign")
  datePreset             String?
  dateStart              DateTime
  dateStop               DateTime
  spend                  Decimal            @default(0) @db.Decimal(12, 2)
  impressions            Int                @default(0)
  clicks                 Int                @default(0)
  linkClicks             Int                @default(0)
  landingPageViews       Int                @default(0)
  addToCart              Int                @default(0)
  initiateCheckout       Int                @default(0)
  purchases              Int                @default(0)
  ctr                    Decimal            @default(0) @db.Decimal(12, 4)
  cpc                    Decimal            @default(0) @db.Decimal(12, 4)
  cpm                    Decimal            @default(0) @db.Decimal(12, 4)
  purchaseRoas           Decimal?           @db.Decimal(12, 4)
  actionsJson            Json?
  purchaseRoasJson       Json?
  syncedAt               DateTime           @default(now())
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  store                  Store              @relation(fields: [storeId], references: [id], onDelete: Cascade)
  metaConnection         MetaAdsConnection? @relation(fields: [metaConnectionId], references: [id], onDelete: SetNull)

  @@unique([storeId, adAccountId, level, entityId, dateStart, dateStop])
  @@index([storeId, dateStart, dateStop])
  @@index([storeId, adAccountId])
  @@index([campaignId])
  @@index([adId])
  @@index([creativeId])
}

model SyncRun {
  id             String    @id @default(cuid())
  storeId        String
  mode           String
  status         String
  startedAt      DateTime  @default(now())
  completedAt    DateTime?
  syncFrom       DateTime?
  recordsCreated Int       @default(0)
  recordsUpdated Int       @default(0)
  recordsFailed  Int       @default(0)
  errorMessage   String?
  detailsJson    Json?
  store          Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId, startedAt(sort: Desc)])
  @@index([status])
}

model Product {
  id                    String                        @id @default(cuid())
  storeId               String
  shopifyProductId      String
  title                 String
  handle                String
  vendor                String?
  productType           String?
  status                String?
  collection            String
  price                 Decimal                       @default(0) @db.Decimal(10, 2)
  estimatedCost         Decimal                       @default(0) @db.Decimal(10, 2)
  costOverrideAmount    Decimal?                      @db.Decimal(10, 2)
  marginProfile         String                        @default("core")
  createdAt             DateTime
  updatedAt             DateTime
  store                 Store                         @relation(fields: [storeId], references: [id], onDelete: Cascade)
  variants              ProductVariant[]
  lineItems             OrderLineItem[]
  collectionMemberships ProductCollectionMembership[]

  @@unique([storeId, shopifyProductId])
  @@index([storeId, updatedAt])
  @@index([storeId, productType])
}

model ShopifyCollection {
  id                  String                        @id @default(cuid())
  storeId             String
  shopifyCollectionId String
  title               String
  handle              String
  isAutomatic         Boolean                       @default(false)
  productsCount       Int                           @default(0)
  updatedAt           DateTime                      @default(now())
  createdAt           DateTime                      @default(now())
  store               Store                         @relation(fields: [storeId], references: [id], onDelete: Cascade)
  memberships         ProductCollectionMembership[]

  @@unique([storeId, shopifyCollectionId])
  @@index([storeId, title])
}

model ProductCollectionMembership {
  id           String            @id @default(cuid())
  storeId      String
  productId    String
  collectionId String
  createdAt    DateTime          @default(now())
  store        Store             @relation(fields: [storeId], references: [id], onDelete: Cascade)
  product      Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  collection   ShopifyCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@unique([productId, collectionId])
  @@index([storeId, collectionId])
  @@index([storeId, productId])
}

model ProductVariant {
  id                String          @id @default(cuid())
  storeId           String
  productId         String
  shopifyVariantId  String
  sku               String?
  barcode           String?
  title             String
  price             Decimal?        @db.Decimal(10, 2)
  compareAtPrice    Decimal?        @db.Decimal(10, 2)
  inventoryQuantity Int?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  store             Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  product           Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  lineItems         OrderLineItem[]

  @@unique([storeId, shopifyVariantId])
  @@index([storeId, sku])
  @@index([storeId, barcode])
  @@index([productId])
}

model Customer {
  id                String    @id @default(cuid())
  storeId           String
  shopifyCustomerId String
  email             String?
  firstName         String?
  lastName          String?
  name              String
  createdAt         DateTime
  updatedAt         DateTime
  firstOrderDate    DateTime?
  totalOrders       Int       @default(0)
  lifetimeValue     Decimal   @default(0) @db.Decimal(12, 2)
  isReturning       Boolean   @default(false)
  store             Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  orders            Order[]

  @@unique([storeId, shopifyCustomerId])
  @@index([storeId, email])
  @@index([storeId, updatedAt])
}

model Order {
  id                    String                 @id @default(cuid())
  storeId               String
  customerId            String?
  shopifyOrderId        String
  orderNumber           String
  displayName           String?
  createdAt             DateTime
  processedAt           DateTime?
  currency              String
  subtotalPrice         Decimal                @default(0) @db.Decimal(12, 2)
  totalDiscounts        Decimal                @default(0) @db.Decimal(12, 2)
  totalTax              Decimal                @default(0) @db.Decimal(12, 2)
  totalShipping         Decimal                @default(0) @db.Decimal(12, 2)
  totalRefunds          Decimal                @default(0) @db.Decimal(12, 2)
  totalPrice            Decimal                @default(0) @db.Decimal(12, 2)
  taxesIncluded         Boolean                @default(false)
  financialStatus       String?
  fulfillmentStatus     String?
  cancelledAt           DateTime?
  test                  Boolean                @default(false)
  sourceName            String?
  // Where the customer first landed on the storefront, with the original
  // query string intact. This is the raw value Shopify sends back from the
  // Admin API — we parse UTM / fbclid / referrer hints out of it at read
  // time inside the channel-performance-engine, not at sync time, so the
  // raw signal is preserved if we ever want to re-bucket.
  landingSiteRef        String?
  // Hostname of the previous page the customer was on when they arrived
  // (e.g. "instagram.com", "google.com"). Shopify's `referring_site` field.
  referringSite         String?
  updatedAt             DateTime
  store                 Store                  @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customer              Customer?              @relation(fields: [customerId], references: [id], onDelete: SetNull)
  lineItems             OrderLineItem[]
  discountUsages        DiscountUsage[]
  refunds               Refund[]
  creatorAttributions   CreatorAttribution[]
  affiliateAttributions AffiliateAttribution[]

  @@unique([storeId, shopifyOrderId])
  @@index([storeId, createdAt])
  @@index([storeId, updatedAt])
  @@index([customerId])
}

model OrderLineItem {
  id                  String          @id @default(cuid())
  storeId             String
  orderId             String
  productId           String?
  variantId           String?
  shopifyLineItemId   String?
  title               String
  quantity            Int
  originalUnitPrice   Decimal         @default(0) @db.Decimal(10, 2)
  discountedUnitPrice Decimal         @default(0) @db.Decimal(10, 2)
  lineSubtotal        Decimal         @default(0) @db.Decimal(12, 2)
  lineDiscountAmount  Decimal         @default(0) @db.Decimal(12, 2)
  taxAmount           Decimal         @default(0) @db.Decimal(12, 2)
  refundedQuantity    Int             @default(0)
  refundedSubtotal    Decimal         @default(0) @db.Decimal(12, 2)
  estimatedCostAmount Decimal         @default(0) @db.Decimal(12, 2)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  store               Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  order               Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product             Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)
  variant             ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@unique([storeId, orderId, shopifyLineItemId])
  @@index([storeId, productId])
  @@index([storeId, variantId])
  @@index([orderId])
}

model DiscountUsage {
  id        String   @id @default(cuid())
  storeId   String
  orderId   String
  code      String
  amount    Decimal  @default(0) @db.Decimal(12, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([storeId, orderId, code])
  @@index([storeId, code])
}

model Refund {
  id                      String   @id @default(cuid())
  storeId                 String
  orderId                 String
  shopifyRefundId         String?
  refundedAmount          Decimal  @default(0) @db.Decimal(12, 2)
  refundedLineItemsAmount Decimal  @default(0) @db.Decimal(12, 2)
  createdAt               DateTime
  store                   Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  order                   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([storeId, shopifyRefundId])
  @@index([storeId, createdAt])
  @@index([orderId])
}

model DailyMetric {
  id                    String   @id @default(cuid())
  storeId               String
  date                  DateTime
  revenue               Decimal  @default(0) @db.Decimal(12, 2)
  estimatedProfit       Decimal  @default(0) @db.Decimal(12, 2)
  returningCustomerRate Decimal  @default(0) @db.Decimal(7, 4)
  averageOrderValue     Decimal  @default(0) @db.Decimal(12, 2)
  discountRate          Decimal  @default(0) @db.Decimal(7, 4)
  refundRate            Decimal  @default(0) @db.Decimal(7, 4)
  ordersCount           Int      @default(0)
  newCustomers          Int      @default(0)
  returningCustomers    Int      @default(0)
  store                 Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, date])
  @@index([storeId, date])
}

model Summary {
  id          String   @id @default(cuid())
  storeId     String
  headline    String
  contentJson Json
  generatedAt DateTime
  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId, generatedAt(sort: Desc)])
}

// Weekly Meta Ads + Instagram report snapshot. Generated automatically every
// Sunday by the weekly-report cron, and on-demand from the UI. We persist
// only the underlying data JSON (KPIs, brands, insights, Instagram blocks);
// the rendered PDF is regenerated on-demand by hitting /print/meta-ads-weekly
// with the stored data so the history view can show any past report without
// keeping multi-megabyte blobs on disk.
//
// kind: "weekly" for the standard Sunday report, "monthly" for the rollup
// generated at month-end that reads the prior 4 weeklies.
model WeeklyReport {
  id          String   @id @default(cuid())
  storeId     String
  kind        String   @default("weekly") // "weekly" | "monthly"
  periodStart DateTime
  periodEnd   DateTime
  dataJson    Json
  insightsJson Json?
  generatedAt DateTime @default(now())
  sentAt      DateTime?
  // Array of email addresses the cron actually sent it to — empty if the
  // report was generated on-demand without a send.
  sentToJson  Json?
  errorMessage String?
  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId, periodEnd(sort: Desc)])
  @@index([storeId, kind, periodEnd(sort: Desc)])
}

// Email recipients for the weekly + monthly automated reports. Managed via
// the Settings page (no admin auth check here — same trust model as the rest
// of the app for now).
model WeeklyReportRecipient {
  id          String   @id @default(cuid())
  storeId     String
  email       String
  displayName String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, email])
  @@index([storeId, active])
}

// Normalized alert table. Every detection engine in the app (restock-hero,
// stockout-imminent, ROAS-collapse, refund-spike, silent-affiliate, sync-fail,
// etc.) WRITES to this table via lib/services/alert-writer-service.ts. The
// Command Center + Alerts page READ from here. Push model — see
// memory/project_north_star_command_center.md.
//
// Migration note: the legacy alerts page reads `explanation`,
// `suggestedAction`, `periodLabel`, `timestamp` via the Alert domain type
// (lib/domain/types.ts). Those columns are kept nullable here and the new
// alert-writer mirrors `description`→`explanation`,
// `recommendedAction`→`suggestedAction`, `createdAt`→`timestamp` on insert.
// Once the legacy Alerts page is replaced by the Command Center we can drop
// the legacy columns in a follow-up migration.
model Alert {
  id                 String    @id @default(cuid())
  storeId            String
  // Stable type slug, e.g. "restock_hero", "stockout_imminent",
  // "roas_collapse", "silent_affiliate", "sync_failure". Used to group and
  // route alerts in the UI and to template their renderer.
  type               String    @default("legacy")
  // critical | high | medium | low. Existing severity values mapped in.
  severity           String
  // open | acknowledged | resolved | ignored. Default open. The UI updates
  // this when the founder takes action.
  status             String    @default("open")
  // Origin engine — Shopify | Meta | BixGrow | Instagram | Calculated.
  // Helps the user understand provenance and lets us route by source.
  source             String    @default("Calculated")
  // Detection engine that wrote this row — e.g. "restock-hero-alert-service".
  // Diagnostic field, surfaced only in admin views.
  detectedBy         String?
  title              String
  // New canonical description field — engines populate this; legacy
  // `explanation` column below mirrors it.
  description        String?
  // New canonical action field — engines populate this; legacy
  // `suggestedAction` column below mirrors it.
  recommendedAction  String?
  // Optional fields for numeric alerts (e.g. ROAS dropped from 5.2x to 1.8x).
  metricName         String?
  currentValue       Decimal?  @db.Decimal(14, 4)
  previousValue      Decimal?  @db.Decimal(14, 4)
  // Click-through targets. relatedEntityType examples: "product", "campaign",
  // "affiliate", "order". relatedEntityId is the row id in the matching table.
  // We don't enforce a relation — different alerts point at different models.
  relatedEntityType  String?
  relatedEntityId    String?
  // Dedup key: detector decides what makes "the same alert," e.g.
  // `restock_hero:<productId>`. Unique with storeId + status so the same
  // fingerprint can re-fire after being resolved (we soft-delete via status).
  fingerprint        String?
  // Free-form JSON for type-specific data the renderer needs (e.g. restock
  // detail blob, top product list, ROAS comparison snapshot). Keeps the
  // model lean while letting each alert type carry rich context.
  payloadJson        Json?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt @default(now())
  // Set when the alert transitions to resolved/acknowledged/ignored.
  resolvedAt         DateTime?
  // Who or what cleared the alert. "user:<email>" | "system:<engine>" | null.
  resolvedBy         String?

  // ─── Legacy columns (kept for backward compatibility with the existing
  // Alerts page). New writers populate them by mirroring the canonical
  // fields. Drop once the Command Center replaces the legacy reader. ───
  explanation        String?
  suggestedAction    String?
  periodLabel        String?
  timestamp          DateTime?

  store              Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)

  // One OPEN alert per (storeId, fingerprint). Including status lets us
  // re-fire a resolved alert with the same fingerprint later.
  @@unique([storeId, fingerprint, status])
  @@index([storeId, status, severity])
  @@index([storeId, type, status])
  @@index([storeId, createdAt(sort: Desc)])
  @@index([storeId, relatedEntityType, relatedEntityId])
  @@index([storeId, timestamp(sort: Desc)])
}

model CreatorProfile {
  id            String               @id @default(cuid())
  storeId       String
  platform      String
  externalId    String
  username      String
  displayName   String?
  profileUrl    String?
  affiliateCode String?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  store         Store                @relation(fields: [storeId], references: [id], onDelete: Cascade)
  posts         CreatorPost[]
  attributions  CreatorAttribution[]

  @@unique([storeId, platform, externalId])
  @@index([storeId, platform])
}

model CreatorPost {
  id                    String               @id @default(cuid())
  storeId               String
  instagramConnectionId String?
  creatorProfileId      String?
  externalPostId        String
  caption               String?
  mediaType             String?
  mediaUrl              String?
  permalink             String?
  postedAt              DateTime
  likeCount             Int                  @default(0)
  commentsCount         Int                  @default(0)
  viewCount             Int                  @default(0)
  attributedSales       Decimal              @default(0) @db.Decimal(12, 2)
  attributedOrders      Int                  @default(0)
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  store                 Store                @relation(fields: [storeId], references: [id], onDelete: Cascade)
  instagramConnection   InstagramConnection? @relation(fields: [instagramConnectionId], references: [id], onDelete: SetNull)
  creatorProfile        CreatorProfile?      @relation(fields: [creatorProfileId], references: [id], onDelete: SetNull)
  attributions          CreatorAttribution[]

  @@unique([storeId, externalPostId])
  @@index([storeId, postedAt])
}

model CreatorAttribution {
  id               String          @id @default(cuid())
  storeId          String
  creatorProfileId String?
  creatorPostId    String?
  orderId          String?
  sourcePlatform   String
  affiliateCode    String?
  salesAmount      Decimal         @default(0) @db.Decimal(12, 2)
  ordersCount      Int             @default(0)
  clicks           Int             @default(0)
  commissionAmount Decimal         @default(0) @db.Decimal(12, 2)
  periodLabel      String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  store            Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  creatorProfile   CreatorProfile? @relation(fields: [creatorProfileId], references: [id], onDelete: SetNull)
  creatorPost      CreatorPost?    @relation(fields: [creatorPostId], references: [id], onDelete: SetNull)
  order            Order?          @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([storeId, sourcePlatform])
  @@index([creatorProfileId])
  @@index([creatorPostId])
}

model AffiliateProgram {
  id             String            @id @default(cuid())
  storeId        String
  name           String
  status         String            @default("active")
  commissionRate Decimal           @default(0.10) @db.Decimal(5, 4)
  signUpLink     String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  store          Store             @relation(fields: [storeId], references: [id], onDelete: Cascade)
  members        AffiliateMember[]

  @@index([storeId, status])
}

model AffiliateMember {
  id                  String                      @id @default(cuid())
  storeId             String
  programId           String?
  firstName           String
  lastName            String
  email               String
  status              String                      @default("pending")
  source              String?
  country             String?
  affiliateCode       String                      @unique
  couponCode          String?
  referralLink        String?
  shortLink           String?
  instagramUsername   String?
  instagramProfileUrl String?
  clicksTotal         Int                         @default(0)
  ordersTotal         Int                         @default(0)
  salesTotal          Decimal                     @default(0) @db.Decimal(12, 2)
  commissionTotal     Decimal                     @default(0) @db.Decimal(12, 2)
  approvedBalance     Decimal                     @default(0) @db.Decimal(12, 2)
  joinedAt            DateTime                    @default(now())
  lastLoginAt         DateTime?
  createdAt           DateTime                    @default(now())
  updatedAt           DateTime                    @updatedAt
  store               Store                       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  program             AffiliateProgram?           @relation(fields: [programId], references: [id], onDelete: SetNull)
  coupons             AffiliateCoupon[]
  couponAssignments   AffiliateCouponAssignment[]
  attributions        AffiliateAttribution[]
  attributionSessions AttributionSession[]

  @@unique([storeId, email])
  @@index([storeId, status])
}

model AffiliateCoupon {
  id                     String                      @id @default(cuid())
  storeId                String
  affiliateMemberId      String?
  shopifyDiscountId      String?
  title                  String
  code                   String
  discountType           String
  discountValue          Decimal                     @db.Decimal(12, 2)
  appliesOncePerCustomer Boolean                     @default(true)
  applyLink              String?
  status                 String                      @default("active")
  createdAt              DateTime                    @default(now())
  updatedAt              DateTime                    @updatedAt
  store                  Store                       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  affiliateMember        AffiliateMember?            @relation(fields: [affiliateMemberId], references: [id], onDelete: SetNull)
  assignments            AffiliateCouponAssignment[]

  @@unique([storeId, code])
  @@index([storeId, affiliateMemberId])
}

model AffiliateCouponAssignment {
  id                String           @id @default(cuid())
  storeId           String
  affiliateMemberId String
  affiliateCouponId String?
  couponCode        String
  couponTitle       String
  discountType      String
  discountValue     Decimal          @db.Decimal(12, 2)
  applyLink         String?
  assignmentMode    String           @default("single")
  connectionSource  String           @default("shopify_create")
  createdAt         DateTime         @default(now())
  store             Store            @relation(fields: [storeId], references: [id], onDelete: Cascade)
  affiliateMember   AffiliateMember  @relation(fields: [affiliateMemberId], references: [id], onDelete: Cascade)
  affiliateCoupon   AffiliateCoupon? @relation(fields: [affiliateCouponId], references: [id], onDelete: SetNull)

  @@index([storeId, affiliateMemberId, createdAt(sort: Desc)])
  @@index([affiliateCouponId])
}

model AffiliateAttribution {
  id                String          @id @default(cuid())
  storeId           String
  affiliateMemberId String
  orderId           String?
  sourceType        String          @default("coupon")
  trackingMethod    String?
  sourceUrl         String?
  contentTitle      String?
  salesAmount       Decimal         @default(0) @db.Decimal(12, 2)
  commissionAmount  Decimal         @default(0) @db.Decimal(12, 2)
  clicks            Int             @default(0)
  ordersCount       Int             @default(1)
  occurredAt        DateTime        @default(now())
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  store             Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  affiliateMember   AffiliateMember @relation(fields: [affiliateMemberId], references: [id], onDelete: Cascade)
  order             Order?          @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@unique([affiliateMemberId, orderId])
  @@index([storeId, occurredAt])
}

model AgentSettings {
  id                    String   @id @default(cuid())
  storeId               String   @unique
  enabled               Boolean  @default(true)
  mode                  String   @default("recommendation_only")
  checkFrequencyMinutes Int      @default(60)
  thresholds            Json
  comparisonWindows     Json
  channels              Json
  notifications         Json
  guardrails            Json
  allowedActions        Json
  approvalRules         Json
  productResearch       Json
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  store                 Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

model AgentFinding {
  id                 String   @id @default(cuid())
  storeId            String
  findingType        String
  severity           String
  metricName         String
  summary            String
  possibleCauses     Json
  recommendedActions Json
  confidenceScore    Decimal  @default(0.65) @db.Decimal(4, 2)
  sourceData         Json?
  createdAt          DateTime @default(now())
  store              Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId, createdAt(sort: Desc)])
  @@index([storeId, severity])
}

model AgentAction {
  id               String    @id @default(cuid())
  storeId          String
  actionType       String
  status           String
  title            String
  reason           String
  payload          Json
  estimatedImpact  Json?
  riskLevel        String
  confidenceScore  Decimal   @default(0.65) @db.Decimal(4, 2)
  approvalRequired Boolean   @default(false)
  approvedBy       String?
  dryRun           Boolean   @default(false)
  executedAt       DateTime?
  failureReason    String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  store            Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId, createdAt(sort: Desc)])
  @@index([storeId, status])
  @@index([storeId, actionType])
}

model PlatformConnection {
  id            String    @id @default(cuid())
  storeId       String
  platform      String
  status        String    @default("not_connected")
  config        Json?
  tokenLastFour String?
  healthMessage String?
  lastSyncAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  store         Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, platform])
  @@index([storeId, status])
}

model MetricSnapshot {
  id              String   @id @default(cuid())
  storeId         String
  source          String
  bucketedAt      DateTime
  metrics         Json
  confidenceScore Decimal? @db.Decimal(4, 2)
  createdAt       DateTime @default(now())
  store           Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId, bucketedAt(sort: Desc)])
  @@index([storeId, source])
}

model AttributionSession {
  id                String           @id @default(cuid())
  storeId           String
  affiliateMemberId String?
  clickId           String           @unique
  visitorToken      String?
  sourcePlatform    String?
  sourceUrl         String?
  destinationUrl    String
  landingPath       String?
  couponCode        String?
  affiliateCode     String?
  utmSource         String?
  utmMedium         String?
  utmCampaign       String?
  ipHash            String?
  userAgent         String?
  convertedAt       DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  store             Store            @relation(fields: [storeId], references: [id], onDelete: Cascade)
  affiliateMember   AffiliateMember? @relation(fields: [affiliateMemberId], references: [id], onDelete: SetNull)

  @@index([storeId, createdAt(sort: Desc)])
  @@index([storeId, affiliateCode])
  @@index([storeId, couponCode])
}

model WebhookEvent {
  id           String    @id @default(cuid())
  storeId      String
  platform     String
  topic        String
  externalId   String?
  status       String    @default("received")
  payload      Json
  errorMessage String?
  processedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  store        Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId, topic, createdAt(sort: Desc)])
  @@index([storeId, status])
}

model OfflineSalesImport {
  id            String            @id @default(cuid())
  storeId       String
  fileName      String
  sheetTitle    String?
  periodYear    Int
  periodMonth   Int
  totalRows     Int               @default(0)
  totalQuantity Decimal           @default(0) @db.Decimal(18, 2)
  totalSales    Decimal           @default(0) @db.Decimal(18, 2)
  currency      String?
  notes         String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  store         Store             @relation(fields: [storeId], references: [id], onDelete: Cascade)
  rows          OfflineSalesRow[]

  @@unique([storeId, periodYear, periodMonth])
  @@index([storeId, createdAt(sort: Desc)])
}

model OfflineSalesRow {
  id               String             @id @default(cuid())
  importId         String
  itemName         String
  barcode          String?
  couponCode       String?
  quantity         Decimal            @default(0) @db.Decimal(18, 2)
  sales            Decimal            @default(0) @db.Decimal(18, 2)
  matchedVariantId String?
  matchedProductId String?
  createdAt        DateTime           @default(now())
  import           OfflineSalesImport @relation(fields: [importId], references: [id], onDelete: Cascade)

  @@index([importId])
  @@index([barcode])
  @@index([couponCode])
}

// Creative studio: AI-generated packshots, IG posts, UGC, Meta ads.
// String columns instead of enums to match the rest of the schema.

model CreativeProject {
  id           String                  @id @default(cuid())
  storeId      String
  name         String
  productId    String?
  creativeType String // "PACKSHOT" | "UGC_VIDEO" | "INSTAGRAM_POST" | "META_AD"
  aspectRatio  String // "1:1" | "4:5" | "9:16" | "16:9"
  status       String                  @default("draft") // "draft" | "generating" | "ready" | "archived"
  provider     String                  @default("replicate") // "replicate" | "higgsfield"
  targetCount  Int                     @default(1)
  briefJson    Json?
  styleJson    Json?
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt
  store        Store                   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  sources      CreativeSource[]
  assets       CreativeAsset[]
  jobs         CreativeGenerationJob[]

  @@index([storeId, createdAt(sort: Desc)])
  @@index([storeId, creativeType])
  @@index([status])
}

model CreativeSource {
  id         String          @id @default(cuid())
  storeId    String
  projectId  String
  kind       String // "USER_UPLOAD" | "SHOPIFY_PRODUCT_IMAGE"
  storageKey String
  mimeType   String
  width      Int?
  height     Int?
  bytes      Int?
  createdAt  DateTime        @default(now())
  store      Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  project    CreativeProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([storeId, createdAt(sort: Desc)])
}

model CreativeAsset {
  id              String                 @id @default(cuid())
  projectId       String
  jobId           String?
  assetType       String // "IMAGE" | "VIDEO"
  status          String                 @default("pending") // "pending" | "rendering" | "ready" | "failed"
  storageKey      String?
  rawStorageKey   String?
  thumbStorageKey String?
  width           Int?
  height          Int?
  durationMs      Int?
  promptUsed      String?
  providerName    String?
  providerJobId   String?
  overlaysJson    Json?
  metaJson        Json?
  errorMessage    String?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  project         CreativeProject        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  job             CreativeGenerationJob? @relation(fields: [jobId], references: [id])

  @@index([projectId, createdAt(sort: Desc)])
  @@index([status])
  @@index([providerJobId])
}

model CreativeGenerationJob {
  id              String          @id @default(cuid())
  storeId         String
  projectId       String
  jobType         String // "GENERATE_BATCH" | "REGEN_ASSET" | "EDIT_IMAGE"
  status          String          @default("queued") // "queued" | "running" | "succeeded" | "failed" | "cancelled"
  targetCount     Int             @default(1)
  succeededCount  Int             @default(0)
  failedCount     Int             @default(0)
  payloadJson     Json
  errorMessage    String?
  startedAt       DateTime?
  completedAt     DateTime?
  attempts        Int             @default(0)
  lockedAt        DateTime?
  lockedBy        String?
  providerName    String?
  costEstimateUsd Decimal?        @db.Decimal(10, 4)
  costActualUsd   Decimal?        @db.Decimal(10, 4)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  store           Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  project         CreativeProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assets          CreativeAsset[]

  @@index([status, createdAt])
  @@index([storeId, status])
  @@index([lockedAt])
}
