generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // DATABASE_URL → runtime connection. In production point this at the
  // Supabase POOLED endpoint (port 6543,
  // ?pgbouncer=true&connection_limit=5&pool_timeout=20). connection_limit=1
  // starves the initial sync (SA-FIX3); lib/prisma.ts normalises a too-small
  // limit at runtime as a safety net.
  url       = env("DATABASE_URL")
  // DIRECT_URL → migrations only (`prisma migrate` / `prisma db push`).
  // PgBouncer's transaction pooling doesn't support prepared statements,
  // so migrations need a direct (port 5432) connection. Falls back to
  // DATABASE_URL when unset (local dev).
  directUrl = env("DIRECT_URL")
}

// ─── SaaS multi-tenant identity layer ────────────────────────────────
// `User` mirrors the Supabase Auth user (we keep `authUserId` linked so
// switching auth providers later is mechanical, not a rewrite).
// `Organization` is the billing entity — one Stripe customer per org.
// `Membership` is the join table — one user can belong to many orgs,
// each with a role.
// Existing `Store` rows gain `orgId` so every analytics query is naturally
// scoped to the caller's organization. Stores remain the connection point
// for Shopify/Meta/Instagram; orgs are who pays.

model User {
  id              String       @id @default(cuid())
  // Supabase Auth user id (from auth.users). Lets us swap auth providers
  // later without rewriting every join — only this column changes.
  authUserId      String       @unique
  email           String       @unique
  displayName     String?
  // User's preferred UI language. Defaults from IP/browser at signup, can
  // be overridden in Settings. Used by the i18n layer on every request.
  locale          String       @default("he")
  // Stamp these on every authenticated request via middleware.
  lastSignInAt    DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  memberships     Membership[]
  invitationsSent Invitation[]
  auditEvents     AuditEvent[]

  @@index([email])
}

model Organization {
  id                   String       @id @default(cuid())
  name                 String
  // URL-friendly slug, used for any future `/org/<slug>/...` routes and
  // as a vanity identifier in support tickets. Globally unique.
  slug                 String       @unique
  // Subscription plan name — "starter" / "growth" / "agency" / "trial".
  // We don't enforce limits here; that's done at action time in services.
  plan                 String       @default("trial")
  // Trial expiry. After this date and without a paid `plan`, the app
  // shows a paywall on every page except billing.
  trialEndsAt          DateTime?
  // Stripe linkage for self-serve billing + customer portal.
  stripeCustomerId     String?      @unique
  stripeSubscriptionId String?      @unique
  // Currency the org pays in. Drives Stripe price selection + display
  // formatting. Lock at signup time (detected from IP/locale).
  currency             String       @default("ILS")
  // Org default locale — used for invoice + email rendering. UI locale
  // is per-user (see User.locale).
  locale               String       @default("he")
  // Where the org is billed from — drives Stripe Tax behavior + VAT.
  billingCountry       String?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  memberships          Membership[]
  stores               Store[]
  invitations          Invitation[]
  auditEvents          AuditEvent[]

  @@index([plan])
}

// Audit log — records security-relevant mutations so owners can answer
// "who did what?". Append-only; never updated or deleted.
//
// Recorded events:
//   - team.invite_sent  / team.invite_revoked / team.member_joined / team.member_role_changed
//   - billing.subscription_started / billing.subscription_canceled / billing.plan_changed
//   - settings.org_updated / settings.shopify_credentials_updated
//   - data.brand_connected / data.brand_disconnected
//
// `actorUserId` may be null when the system itself is the actor
// (Stripe webhook firing, cron auto-action). `targetType` + `targetId`
// describe what was affected.
model AuditEvent {
  id          String       @id @default(cuid())
  orgId       String
  actorUserId String?
  // Event type — e.g. "team.invite_sent", "billing.subscription_started"
  eventType   String
  // Free-form description for the viewer ("Invited dana@example.com as member")
  description String
  // Optional structured fields
  targetType  String?
  targetId    String?
  // Useful for forensics: client IP, user agent, etc.
  metadata    Json?
  createdAt   DateTime     @default(now())
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  actor       User?        @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([orgId, createdAt])
  @@index([eventType])
}

// Team invitations. Generated by an owner/admin, sent via email.
// Recipient signs up or signs in with the matching email, then accepts.
// On accept we delete the row + create a Membership.
//
// Stateful workflow:
//   - pending: just created, waiting for recipient to accept
//   - accepted: deleted (became a Membership)
//   - expired: more than 14 days old, ignored on accept attempts
//   - revoked: owner/admin canceled before acceptance (also deleted)
model Invitation {
  id          String       @id @default(cuid())
  orgId       String
  email       String
  role        String       @default("member")
  // The user who sent the invite — used in the accept email body
  // ("Yohad invited you to join…").
  invitedById String
  // Random token in the URL the recipient clicks. We rotate this if the
  // invite is re-sent, so old emails stop working.
  token       String       @unique
  expiresAt   DateTime
  createdAt   DateTime     @default(now())
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  invitedBy   User         @relation(fields: [invitedById], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([email])
}

// One row per (user, org) pair. The role gates what the user can do
// inside that org. Owners cannot be removed by other members; deleting
// the owner role on a user requires the user themselves to leave.
model Membership {
  id        String       @id @default(cuid())
  userId    String
  orgId     String
  // owner = full control + billing
  // admin = manage stores + invite teammates, no billing/delete
  // member = read+write all analytics, no settings changes
  role      String       @default("member")
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([userId, orgId])
  @@index([orgId])
}

model Store {
  id                         String                        @id @default(cuid())
  // Multi-tenant scoping key. Every store belongs to exactly one org.
  // Nullable for backwards-compat during the Phase 1 migration; will be
  // set to NOT NULL after the backfill step (Milestone 1F).
  orgId                      String?
  name                       String
  domain                     String                        @unique
  shopifyShopId              String?                       @unique
  currency                   String
  timezone                   String
  planName                   String?
  connected                  Boolean                       @default(false)
  dateRangePreset            String                        @default("30d")
  estimatedCostMode          String                        @default("margin_profile")
  defaultCostRatio           Decimal                       @default(0.35) @db.Decimal(5, 4)
  // Short URL slug used by the per-brand BixGrow webhook
  // (/api/webhooks/bixgrow/<bixgrowSlug>). Auto-generated from the brand
  // name on first install, editable from the Settings page. Globally
  // unique so two brands can't collide on the same webhook URL.
  bixgrowSlug                String?                       @unique
  org                        Organization?                 @relation(fields: [orgId], references: [id], onDelete: Cascade)
  connection                 ShopifyConnection?
  bixgrowConnection          BixGrowConnection?
  instagramConnection        InstagramConnection?
  metaAdsConnection          MetaAdsConnection?
  products                   Product[]
  variants                   ProductVariant[]
  customers                  Customer[]
  orders                     Order[]
  lineItems                  OrderLineItem[]
  discountUsages             DiscountUsage[]
  refunds                    Refund[]
  dailyMetrics               DailyMetric[]
  summaries                  Summary[]
  alerts                     Alert[]
  syncRuns                   SyncRun[]
  creatorProfiles            CreatorProfile[]
  creatorPosts               CreatorPost[]
  creatorAttributions        CreatorAttribution[]
  affiliatePrograms          AffiliateProgram[]
  affiliateMembers           AffiliateMember[]
  affiliateCoupons           AffiliateCoupon[]
  affiliateCouponAssignments AffiliateCouponAssignment[]
  affiliateAttributions      AffiliateAttribution[]
  agentSettings              AgentSettings?
  agentFindings              AgentFinding[]
  agentActions               AgentAction[]
  platformConnections        PlatformConnection[]
  metricSnapshots            MetricSnapshot[]
  metaAdsCampaignInsights    MetaAdsCampaignInsight[]
  attributionSessions        AttributionSession[]
  webhookEvents              WebhookEvent[]
  shopifyCollections         ShopifyCollection[]
  productCollections         ProductCollectionMembership[]
  offlineSalesImports        OfflineSalesImport[]
  creativeProjects           CreativeProject[]
  creativeSources            CreativeSource[]
  creativeJobs               CreativeGenerationJob[]
  creativeSprints            CreativeSprint[]
  sprintAds                  SprintAd[]
  weeklyReports              WeeklyReport[]
  weeklyReportRecipients     WeeklyReportRecipient[]
  searchConsoleMetrics       SearchConsoleMetric[]
  searchConsolePages         SearchConsolePage[]
  searchConsoleQueries       SearchConsoleQuery[]
  ganttSheets                GanttSheet[]
  ganttRows                  GanttRow[]
  createdAt                  DateTime                      @default(now())
  updatedAt                  DateTime                      @updatedAt

  @@index([connected])
  @@index([orgId])
}

model ShopifyConnection {
  id                   String    @id @default(cuid())
  storeId              String    @unique
  shopDomain           String
  adminAccessTokenEnc  String
  tokenLastFour        String
  apiVersion           String    @default("2025-01")
  webhookIds           String[]  @default([])
  webhooksRegisteredAt DateTime?
  lastSyncAt           DateTime?
  lastProductsSyncAt   DateTime?
  lastCustomersSyncAt  DateTime?
  lastOrdersSyncAt     DateTime?
  lastSuccessfulSyncAt DateTime?
  syncStatus           String    @default("idle")
  lastSyncError        String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  store                Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([shopDomain])
  @@index([syncStatus])
}

model BixGrowConnection {
  id            String    @id @default(cuid())
  storeId       String    @unique
  portalDomain  String
  apiKeyEnc     String?
  tokenLastFour String?
  syncStatus    String    @default("idle")
  exportMode    String    @default("manual_export")
  lastSyncAt    DateTime?
  lastSyncError String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  store         Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([portalDomain])
}

model InstagramConnection {
  id              String        @id @default(cuid())
  storeId         String        @unique
  instagramUserId String
  username        String?
  accessTokenEnc  String
  tokenLastFour   String
  syncStatus      String        @default("idle")
  lastSyncAt      DateTime?
  lastSyncError   String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  store           Store         @relation(fields: [storeId], references: [id], onDelete: Cascade)
  posts           CreatorPost[]

  @@index([instagramUserId])
}

model MetaAdsConnection {
  id               String                   @id @default(cuid())
  storeId          String                   @unique
  adAccountId      String
  adAccountName    String?
  accountStatus    Int?
  currency         String?
  timezoneName     String?
  appId            String?
  appSecretEnc     String?
  accessTokenEnc   String
  tokenLastFour    String
  tokenType        String?
  tokenIssuedAt    DateTime?
  tokenExpiresAt   DateTime?
  tokenScopes      Json?
  syncStatus       String                   @default("idle")
  lastSyncAt       DateTime?
  lastSyncError    String?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  store            Store                    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  campaignInsights MetaAdsCampaignInsight[]

  @@index([adAccountId])
  @@index([syncStatus])
}

model MetaAdsCampaignInsight {
  id                     String             @id @default(cuid())
  storeId                String
  metaConnectionId       String?
  adAccountId            String
  entityId               String             @default("")
  campaignId             String
  campaignName           String
  adsetId                String?
  adsetName              String?
  adId                   String?
  adName                 String?
  creativeId             String?
  creativeName           String?
  creativeTitle          String?
  creativeBody           String?
  creativeThumbnailUrl   String?
  creativePreviewUrl     String?
  creativePermalinkUrl   String?
  creativeObjectUrl      String?
  objectStoryId          String?
  effectiveObjectStoryId String?
  level                  String             @default("campaign")
  datePreset             String?
  dateStart              DateTime
  dateStop               DateTime
  spend                  Decimal            @default(0) @db.Decimal(12, 2)
  impressions            Int                @default(0)
  clicks                 Int                @default(0)
  linkClicks             Int                @default(0)
  landingPageViews       Int                @default(0)
  addToCart              Int                @default(0)
  initiateCheckout       Int                @default(0)
  purchases              Int                @default(0)
  ctr                    Decimal            @default(0) @db.Decimal(12, 4)
  cpc                    Decimal            @default(0) @db.Decimal(12, 4)
  cpm                    Decimal            @default(0) @db.Decimal(12, 4)
  purchaseRoas           Decimal?           @db.Decimal(12, 4)
  actionsJson            Json?
  purchaseRoasJson       Json?
  syncedAt               DateTime           @default(now())
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  store                  Store              @relation(fields: [storeId], references: [id], onDelete: Cascade)
  metaConnection         MetaAdsConnection? @relation(fields: [metaConnectionId], references: [id], onDelete: SetNull)

  @@unique([storeId, adAccountId, level, entityId, dateStart, dateStop])
  @@index([storeId, dateStart, dateStop])
  @@index([storeId, adAccountId])
  @@index([campaignId])
  @@index([adId])
  @@index([creativeId])
}

// Global key/value config — values that aren't tied to a single store.
// Example: the Shopify Partner app credentials (Client ID + Client Secret)
// that authorize the OAuth install flow across every tenant.
// Encrypted values use the same encryptSecret() helper as other secrets.
model SystemConfig {
  key       String   @id
  value     String
  encrypted Boolean  @default(false)
  updatedAt DateTime @updatedAt
}

model SyncRun {
  id             String    @id @default(cuid())
  storeId        String
  mode           String
  status         String
  startedAt      DateTime  @default(now())
  completedAt    DateTime?
  syncFrom       DateTime?
  recordsCreated Int       @default(0)
  recordsUpdated Int       @default(0)
  recordsFailed  Int       @default(0)
  errorMessage   String?
  detailsJson    Json?
  store          Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId, startedAt(sort: Desc)])
  @@index([status])
}

model Product {
  id                    String                        @id @default(cuid())
  storeId               String
  shopifyProductId      String
  title                 String
  handle                String
  vendor                String?
  productType           String?
  status                String?
  collection            String
  price                 Decimal                       @default(0) @db.Decimal(10, 2)
  estimatedCost         Decimal                       @default(0) @db.Decimal(10, 2)
  costOverrideAmount    Decimal?                      @db.Decimal(10, 2)
  marginProfile         String                        @default("core")
  createdAt             DateTime
  updatedAt             DateTime
  store                 Store                         @relation(fields: [storeId], references: [id], onDelete: Cascade)
  variants              ProductVariant[]
  lineItems             OrderLineItem[]
  collectionMemberships ProductCollectionMembership[]

  @@unique([storeId, shopifyProductId])
  @@index([storeId, updatedAt])
  @@index([storeId, productType])
}

model ShopifyCollection {
  id                  String                        @id @default(cuid())
  storeId             String
  shopifyCollectionId String
  title               String
  handle              String
  isAutomatic         Boolean                       @default(false)
  productsCount       Int                           @default(0)
  updatedAt           DateTime                      @default(now())
  createdAt           DateTime                      @default(now())
  store               Store                         @relation(fields: [storeId], references: [id], onDelete: Cascade)
  memberships         ProductCollectionMembership[]

  @@unique([storeId, shopifyCollectionId])
  @@index([storeId, title])
}

model ProductCollectionMembership {
  id           String            @id @default(cuid())
  storeId      String
  productId    String
  collectionId String
  createdAt    DateTime          @default(now())
  store        Store             @relation(fields: [storeId], references: [id], onDelete: Cascade)
  product      Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  collection   ShopifyCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@unique([productId, collectionId])
  @@index([storeId, collectionId])
  @@index([storeId, productId])
}

model ProductVariant {
  id                String          @id @default(cuid())
  storeId           String
  productId         String
  shopifyVariantId  String
  sku               String?
  barcode           String?
  title             String
  price             Decimal?        @db.Decimal(10, 2)
  compareAtPrice    Decimal?        @db.Decimal(10, 2)
  inventoryQuantity Int?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  store             Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  product           Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  lineItems         OrderLineItem[]

  @@unique([storeId, shopifyVariantId])
  @@index([storeId, sku])
  @@index([storeId, barcode])
  @@index([productId])
}

model Customer {
  id                String    @id @default(cuid())
  storeId           String
  shopifyCustomerId String
  email             String?
  firstName         String?
  lastName          String?
  name              String
  createdAt         DateTime
  updatedAt         DateTime
  firstOrderDate    DateTime?
  totalOrders       Int       @default(0)
  lifetimeValue     Decimal   @default(0) @db.Decimal(12, 2)
  isReturning       Boolean   @default(false)
  store             Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  orders            Order[]

  @@unique([storeId, shopifyCustomerId])
  @@index([storeId, email])
  @@index([storeId, updatedAt])
}

model Order {
  id                    String                 @id @default(cuid())
  storeId               String
  customerId            String?
  shopifyOrderId        String
  orderNumber           String
  displayName           String?
  createdAt             DateTime
  processedAt           DateTime?
  currency              String
  subtotalPrice         Decimal                @default(0) @db.Decimal(12, 2)
  totalDiscounts        Decimal                @default(0) @db.Decimal(12, 2)
  totalTax              Decimal                @default(0) @db.Decimal(12, 2)
  totalShipping         Decimal                @default(0) @db.Decimal(12, 2)
  totalRefunds          Decimal                @default(0) @db.Decimal(12, 2)
  totalPrice            Decimal                @default(0) @db.Decimal(12, 2)
  taxesIncluded         Boolean                @default(false)
  financialStatus       String?
  fulfillmentStatus     String?
  cancelledAt           DateTime?
  test                  Boolean                @default(false)
  sourceName            String?
  // Where the customer first landed on the storefront, with the original
  // query string intact. This is the raw value Shopify sends back from the
  // Admin API — we parse UTM / fbclid / referrer hints out of it at read
  // time inside the channel-performance-engine, not at sync time, so the
  // raw signal is preserved if we ever want to re-bucket.
  landingSiteRef        String?
  // Hostname of the previous page the customer was on when they arrived
  // (e.g. "instagram.com", "google.com"). Shopify's `referring_site` field.
  referringSite         String?
  updatedAt             DateTime
  store                 Store                  @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customer              Customer?              @relation(fields: [customerId], references: [id], onDelete: SetNull)
  lineItems             OrderLineItem[]
  discountUsages        DiscountUsage[]
  refunds               Refund[]
  creatorAttributions   CreatorAttribution[]
  affiliateAttributions AffiliateAttribution[]

  @@unique([storeId, shopifyOrderId])
  @@index([storeId, createdAt])
  @@index([storeId, updatedAt])
  @@index([customerId])
}

model OrderLineItem {
  id                  String          @id @default(cuid())
  storeId             String
  orderId             String
  productId           String?
  variantId           String?
  shopifyLineItemId   String?
  title               String
  quantity            Int
  originalUnitPrice   Decimal         @default(0) @db.Decimal(10, 2)
  discountedUnitPrice Decimal         @default(0) @db.Decimal(10, 2)
  lineSubtotal        Decimal         @default(0) @db.Decimal(12, 2)
  lineDiscountAmount  Decimal         @default(0) @db.Decimal(12, 2)
  taxAmount           Decimal         @default(0) @db.Decimal(12, 2)
  refundedQuantity    Int             @default(0)
  refundedSubtotal    Decimal         @default(0) @db.Decimal(12, 2)
  estimatedCostAmount Decimal         @default(0) @db.Decimal(12, 2)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  store               Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  order               Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product             Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)
  variant             ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@unique([storeId, orderId, shopifyLineItemId])
  @@index([storeId, productId])
  @@index([storeId, variantId])
  @@index([orderId])
}

model DiscountUsage {
  id        String   @id @default(cuid())
  storeId   String
  orderId   String
  code      String
  amount    Decimal  @default(0) @db.Decimal(12, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([storeId, orderId, code])
  @@index([storeId, code])
}

model Refund {
  id                      String   @id @default(cuid())
  storeId                 String
  orderId                 String
  shopifyRefundId         String?
  refundedAmount          Decimal  @default(0) @db.Decimal(12, 2)
  refundedLineItemsAmount Decimal  @default(0) @db.Decimal(12, 2)
  createdAt               DateTime
  store                   Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  order                   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([storeId, shopifyRefundId])
  @@index([storeId, createdAt])
  @@index([orderId])
}

model DailyMetric {
  id                    String   @id @default(cuid())
  storeId               String
  date                  DateTime
  revenue               Decimal  @default(0) @db.Decimal(12, 2)
  estimatedProfit       Decimal  @default(0) @db.Decimal(12, 2)
  returningCustomerRate Decimal  @default(0) @db.Decimal(7, 4)
  averageOrderValue     Decimal  @default(0) @db.Decimal(12, 2)
  discountRate          Decimal  @default(0) @db.Decimal(7, 4)
  refundRate            Decimal  @default(0) @db.Decimal(7, 4)
  ordersCount           Int      @default(0)
  newCustomers          Int      @default(0)
  returningCustomers    Int      @default(0)
  store                 Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, date])
  @@index([storeId, date])
}

model Summary {
  id          String   @id @default(cuid())
  storeId     String
  headline    String
  contentJson Json
  generatedAt DateTime
  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId, generatedAt(sort: Desc)])
}

// Weekly Meta Ads + Instagram report snapshot. Generated automatically every
// Sunday by the weekly-report cron, and on-demand from the UI. We persist
// only the underlying data JSON (KPIs, brands, insights, Instagram blocks);
// the rendered PDF is regenerated on-demand by hitting /print/meta-ads-weekly
// with the stored data so the history view can show any past report without
// keeping multi-megabyte blobs on disk.
//
// kind: "weekly" for the standard Sunday report, "monthly" for the rollup
// generated at month-end that reads the prior 4 weeklies.
model WeeklyReport {
  id           String    @id @default(cuid())
  storeId      String
  kind         String    @default("weekly") // "weekly" | "monthly"
  periodStart  DateTime
  periodEnd    DateTime
  dataJson     Json
  insightsJson Json?
  generatedAt  DateTime  @default(now())
  sentAt       DateTime?
  // Array of email addresses the cron actually sent it to — empty if the
  // report was generated on-demand without a send.
  sentToJson   Json?
  errorMessage String?
  store        Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId, periodEnd(sort: Desc)])
  @@index([storeId, kind, periodEnd(sort: Desc)])
}

// Email recipients for the weekly + monthly automated reports. Managed via
// the Settings page (no admin auth check here — same trust model as the rest
// of the app for now).
model WeeklyReportRecipient {
  id          String   @id @default(cuid())
  storeId     String
  email       String
  displayName String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, email])
  @@index([storeId, active])
}

// Normalized alert table. Every detection engine in the app (restock-hero,
// stockout-imminent, ROAS-collapse, refund-spike, silent-affiliate, sync-fail,
// etc.) WRITES to this table via lib/services/alert-writer-service.ts. The
// Command Center + Alerts page READ from here. Push model — see
// memory/project_north_star_command_center.md.
//
// Migration note: the legacy alerts page reads `explanation`,
// `suggestedAction`, `periodLabel`, `timestamp` via the Alert domain type
// (lib/domain/types.ts). Those columns are kept nullable here and the new
// alert-writer mirrors `description`→`explanation`,
// `recommendedAction`→`suggestedAction`, `createdAt`→`timestamp` on insert.
// Once the legacy Alerts page is replaced by the Command Center we can drop
// the legacy columns in a follow-up migration.
model Alert {
  id                String    @id @default(cuid())
  storeId           String
  // Stable type slug, e.g. "restock_hero", "stockout_imminent",
  // "roas_collapse", "silent_affiliate", "sync_failure". Used to group and
  // route alerts in the UI and to template their renderer.
  type              String    @default("legacy")
  // critical | high | medium | low. Existing severity values mapped in.
  severity          String
  // open | acknowledged | resolved | ignored. Default open. The UI updates
  // this when the founder takes action.
  status            String    @default("open")
  // Origin engine — Shopify | Meta | BixGrow | Instagram | Calculated.
  // Helps the user understand provenance and lets us route by source.
  source            String    @default("Calculated")
  // Detection engine that wrote this row — e.g. "restock-hero-alert-service".
  // Diagnostic field, surfaced only in admin views.
  detectedBy        String?
  title             String
  // New canonical description field — engines populate this; legacy
  // `explanation` column below mirrors it.
  description       String?
  // New canonical action field — engines populate this; legacy
  // `suggestedAction` column below mirrors it.
  recommendedAction String?
  // Optional fields for numeric alerts (e.g. ROAS dropped from 5.2x to 1.8x).
  metricName        String?
  currentValue      Decimal?  @db.Decimal(14, 4)
  previousValue     Decimal?  @db.Decimal(14, 4)
  // Click-through targets. relatedEntityType examples: "product", "campaign",
  // "affiliate", "order". relatedEntityId is the row id in the matching table.
  // We don't enforce a relation — different alerts point at different models.
  relatedEntityType String?
  relatedEntityId   String?
  // Dedup key: detector decides what makes "the same alert," e.g.
  // `restock_hero:<productId>`. Unique with storeId + status so the same
  // fingerprint can re-fire after being resolved (we soft-delete via status).
  fingerprint       String?
  // Free-form JSON for type-specific data the renderer needs (e.g. restock
  // detail blob, top product list, ROAS comparison snapshot). Keeps the
  // model lean while letting each alert type carry rich context.
  payloadJson       Json?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @default(now()) @updatedAt
  // Set when the alert transitions to resolved/acknowledged/ignored.
  resolvedAt        DateTime?
  // Who or what cleared the alert. "user:<email>" | "system:<engine>" | null.
  resolvedBy        String?

  // ─── Legacy columns (kept for backward compatibility with the existing
  // Alerts page). New writers populate them by mirroring the canonical
  // fields. Drop once the Command Center replaces the legacy reader. ───
  explanation     String?
  suggestedAction String?
  periodLabel     String?
  timestamp       DateTime?

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  // One OPEN alert per (storeId, fingerprint). Including status lets us
  // re-fire a resolved alert with the same fingerprint later.
  @@unique([storeId, fingerprint, status])
  @@index([storeId, status, severity])
  @@index([storeId, type, status])
  @@index([storeId, createdAt(sort: Desc)])
  @@index([storeId, relatedEntityType, relatedEntityId])
  @@index([storeId, timestamp(sort: Desc)])
}

